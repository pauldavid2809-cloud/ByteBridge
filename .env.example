# ============================================================
# Variables de entorno — copia este archivo como .env.local
# y rellena con los datos de tu proyecto de Supabase:
# Dashboard → Project Settings → API
# ============================================================

# URL del proyecto (ej. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (es segura de exponer: la tabla leads
# solo permite INSERT gracias a Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
